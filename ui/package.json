{
  "name": "sundeck-ui",
  "version": "1.0.0",
  "description": "Steam game launcher UI for Apollo/Sunshine",
  "scripts": {
    "build": "esbuild renderer.tsx --bundle --outfile=renderer.bundle.js --platform=browser --format=iife --jsx=automatic",
    "watch": "esbuild renderer.tsx --bundle --outfile=renderer.bundle.js --platform=browser --format=iife --jsx=automatic --watch=forever",
    "test": "jest"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transform": {
      "\\.[jt]sx?$": "babel-jest"
    },
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.27.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "babel-jest": "^30.3.0",
    "esbuild": "^0.27.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@babel/standalone": "^7.29.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
